# Copy this file to ".env" and fill in your values.
# Vite only exposes variables prefixed with VITE_ to the app.
#
# IMPORTANT: these values are embedded at BUILD time (npm run build), so you
# must rebuild/redeploy after changing them. None of these are secrets —
# Client ID and Tenant ID are public identifiers, safe to ship in the bundle.
#
# See SETUP_AND_RUN.md for exactly where each value comes from.

# Azure app registration → Overview → "Application (client) ID"
VITE_CLIENT_ID=your-client-id-guid

# Azure app registration → Overview → "Directory (tenant) ID"
VITE_TENANT_ID=your-tenant-id-guid

# SharePoint Excel share link (copied from the browser)
VITE_EXCEL_FILE_URL=https://yourtenant.sharepoint.com/:x:/s/Site/xxxxx

# SharePoint FMEA (risk register) share link. Optional — if unset, the app uses
# the built-in default in authConfig.js. Rows are matched to initiatives by name.
VITE_FMEA_FILE_URL=https://yourtenant.sharepoint.com/:x:/s/Site/fmea-xxxxx

# Comma-separated emails allowed to edit task status (others are view-only)
VITE_ADMIN_EMAILS=person1@example.com,person2@example.com
